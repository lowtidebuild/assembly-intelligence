# Assembly Intelligence Dashboard — environment variables
# Copy this to .env.local and fill in real values
# .env.local is gitignored — never commit real keys
# For production: same variable names go into GitHub Secrets / Vercel Env Vars

# === assembly-api-mcp (National Assembly Open API via MCP) ===
# Get from: https://open.assembly.go.kr (10 min signup)
# Used by: src/lib/mcp-client.ts
ASSEMBLY_API_MCP_KEY=

# Optional: point the app at your own assembly-api-mcp deployment.
# Leave empty to use the public upstream server.
ASSEMBLY_API_MCP_BASE_URL=

# Optional: choose which MCP profile the app should use.
# Recommended: full (11 tools, includes research_data/get_nabo)
MCP_PROFILE=full

# === Gemini API (Google AI Studio) ===
# Get from: https://aistudio.google.com/apikey (free tier generous for MVP)
# Used by: src/lib/gemini-client.ts (Flash for screening, Pro for analysis/briefing)
GEMINI_API_KEY=

# === Naver Developers — News Search API ===
# Get from: https://developers.naver.com (sign up + register app + enable News Search)
# Used by: src/lib/news-client.ts
# Free tier: 25,000 calls/day
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# === Database (Neon Postgres) ===
# Get from: https://console.neon.tech (free tier)
# Format: postgresql://user:password@host/dbname
DATABASE_URL=

# === App auth (shared password gate, MVP only) ===
# Pick anything strong. Same value for everyone on the team.
# Replace with SSO post-greenlight.
APP_PASSWORD=

# === App config ===
# Industry profile slug (e.g., "game", "bio", "fintech")
# Determines which keywords/prompts the system uses
INDUSTRY_PROFILE=
